# Salin file ini menjadi .env lalu sesuaikan nilainya

# Koneksi PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL="postgresql://postgres:password@localhost:5432/kos_db?schema=public"

# Port server backend
PORT=5000

# Secret untuk JWT (ganti dengan string acak yang panjang & rahasia)
JWT_SECRET="ganti_dengan_secret_key_yang_aman"
JWT_EXPIRES_IN="7d"

# URL frontend (untuk CORS)
FRONTEND_URL="http://localhost:3000"
