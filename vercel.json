{
  "version": 2,
  "buildCommand": "npm install && npx prisma migrate deploy && npm run prisma:generate && npm run build",
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/server.js"
    }
  ]
}

